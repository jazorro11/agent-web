# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (used by LangGraph checkpointer — must be the direct URL, not the pooler)
# In Supabase: Settings → Database → Connection string → URI (mode: Session/Direct, not Transaction)
DATABASE_URL=

# OpenRouter
OPENROUTER_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Calendar OAuth (optional) — used for token refresh server-side; set in the same env as the Next.js app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit base URL for Google OAuth callback (defaults to request origin in dev)
GOOGLE_OAUTH_BASE_URL=

# Notion OAuth (optional) — create a Public Integration at notion.so/my-integrations
# Redirect URI to configure: {NEXT_PUBLIC_SITE_URL}/api/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Public site URL (must match the callback URL configured in the GitHub OAuth App)
NEXT_PUBLIC_SITE_URL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# OAuth encryption
OAUTH_ENCRYPTION_KEY=

# Bash tool (optional, high-risk)
# Set to "true" to enable execution of bash commands on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
BASH_TOOL_ENABLED=
# Absolute path to use as working directory for bash commands.
# Defaults to process.cwd() if unset or invalid.
BASH_TOOL_CWD=

# File tools (optional, read_file / write_file / edit_file)
# Set FILE_TOOLS_ENABLED=true to enable file read/write/edit operations on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
# Paths passed to file tools can be absolute or relative to the server process working directory,
# matching the same behaviour as the bash tool — no root confinement is enforced.
FILE_TOOLS_ENABLED=

# Scheduled tasks cron runner
# A secret token that Supabase Cron (or any external caller) must send in the
# Authorization header as "Bearer <value>" when hitting /api/cron/scheduled-tasks.
# Leave empty to disable authentication (not recommended for production).
CRON_SECRET=

# Debug logging (optional)
# Set to "true" to enable verbose agent logs ([agent], [tools], [fileTools], [chat]).
# Off by default — do not enable in production.
AGENT_DEBUG_LOGS=

# Demo mode (optional)
# Create a dedicated Supabase account for the portfolio demo with is_demo_user=true in profiles.
# Use dedicated accounts for each integration (GitHub, Google, Notion) with read-only scopes.
# NEVER use personal accounts or tokens — demo credentials are shared with all visitors.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Next.js (optional)
NEXT_ALLOWED_DEV_ORIGINS=
